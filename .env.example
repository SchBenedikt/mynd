# ============================================================================
# MYND Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git!
# ============================================================================

# -------- BACKEND --------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5001
FLASK_ENV=production
MYND_DEBUG=0
FLASK_SECRET_KEY=change-me-in-production

# -------- AI (Ollama) --------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest

# -------- NEXTCLOUD INTEGRATION --------
NEXTCLOUD_URL=https://your-nextcloud-instance.com
NEXTCLOUD_USERNAME=your_username
NEXTCLOUD_PASSWORD=your_password
NEXTCLOUD_AUTH_TYPE=login_flow_v2
NEXTCLOUD_DISPLAY_NAME=Your Display Name

# -------- IMMICH INTEGRATION --------
IMMICH_URL=https://your-immich-instance.com
IMMICH_API_KEY=your_immich_api_key_here

# -------- CALENDAR --------
CALENDAR_ENABLED=false
DEFAULT_CALENDAR_NAME=Calendar
CALENDAR_AUTO_REINDEX_HOURS=6

# -------- TASKS (Nextcloud Tasks) --------
TASKS_AUTO_SYNC_ENABLED=true
TASKS_AUTO_SYNC_INTERVAL_SECONDS=300
TASKS_AUTO_SYNC_LIST_NAME=todo

# -------- FRONTEND --------
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001

# -------- SECURITY --------
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
CORS_ORIGINS=http://localhost:3000
SESSION_COOKIE_SECURE=false

# -------- NEXTCLOUD TALK BOT --------
NEXTCLOUD_TALK_BOT_USER=mynd-bot
NEXTCLOUD_TALK_BOT_APP_PASSWORD=replace_with_app_password
NEXTCLOUD_TALK_ROOM_TOKEN=replace_with_room_token
NEXTCLOUD_TALK_WEBHOOK_URL=replace_with_webhook_url

# -------- OPTIONAL INTEGRATIONS --------
OPENWEATHER_API_KEY=
NINA_ENABLED=false
ALLOW_PRIVATE_NETWORK_TARGETS=false
