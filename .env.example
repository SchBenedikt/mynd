# Nextcloud LightRAG Configuration
# Copy this file to .env and fill in your values

# Nextcloud WebDAV Settings
NEXTCLOUD_URL=https://your-nextcloud-instance.com
NEXTCLOUD_USERNAME=your_username
NEXTCLOUD_PASSWORD=your_password
NEXTCLOUD_WEBDAV_PATH=/remote.php/dav/files/your_username/

# Sync Settings
SYNC_INTERVAL_SECONDS=300
SYNC_FOLDERS=Documents,Notes,Projects
SYNC_FILE_EXTENSIONS=.md,.txt,.docx,.pdf

# LightRAG Model Settings
LLM_MODEL=qwen2.5:7b
EMBEDDING_MODEL=nomic-embed-text

# Optional: Reranker model for better retrieval
RERANKER_MODEL=bge-reranker-v2-m3

# Parsing Settings
PDF_PARSER=docling
CHUNK_SIZE=1200
CHUNK_OVERLAP=100

# Paths (usually don't need to change)
PARSED_DOCS_PATH=./parsed_docs
SYNC_STATE_FILE=./data/sync_state.json
LOG_LEVEL=INFO